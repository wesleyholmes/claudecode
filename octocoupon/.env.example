# ── Affiliate Networks ─────────────────────────────────────────────────────────

# Rakuten Advertising (formerly LinkShare)
# Static Bearer token from dashboard (Account → Settings → API)
RAKUTEN_TOKEN=
RAKUTEN_SID=          # Your Publisher Site ID

# Commission Junction (CJ Affiliate)
CJ_API_KEY=
CJ_CID=                    # Your CJ publisher ID

# Optimise Media
OPTIMISE_API_KEY=
OPTIMISE_PUBLISHER_ID=

# ── WordPress Multisite ────────────────────────────────────────────────────────
WP_BASE_URL=https://octocoupon.com
WP_USERNAME=
WP_APP_PASSWORD=           # WordPress Application Password (Settings → Users → Application Passwords)

# ── AI Content Generation ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Social: Facebook & Instagram (Meta Graph API) ─────────────────────────────
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=     # Long-lived Page token

INSTAGRAM_ACCOUNT_ID=      # Instagram Business Account ID (linked to the Page)
INSTAGRAM_ACCESS_TOKEN=    # Same long-lived token works for IG Graph API

# ── Social: Threads (Meta) ────────────────────────────────────────────────────
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── Social: Twitter / X (OAuth 1.0a) ─────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Social: Reddit ────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT_US=deals

# ── Social: Rednote / 小红书 ───────────────────────────────────────────────────
# No official API. Use a cookie exported from a logged-in browser session.
# Extension: "Cookie Editor" → export → paste the full Cookie header value below.
REDNOTE_COOKIE=

# ── Scheduler (cron expressions, UTC) ────────────────────────────────────────
CRON_AFFILIATE_SYNC=0 */6 * * *       # every 6 hours
CRON_CONTENT_PUBLISH=0 9,17 * * *     # 9am and 5pm
CRON_SOCIAL_POST=30 9,17 * * *        # 30 min after WP publish

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=~/.octocoupon/octocoupon.db
MAX_PUBLISH_PER_RUN=5                 # coupons published per country per run
